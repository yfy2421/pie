{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src/server/main.ts", "src/server/server.ts", "src/agent/**/*.ts"],
  "exclude": ["example", "node_modules", "dist", "dist-electron"]
}
